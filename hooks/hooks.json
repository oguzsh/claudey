{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" git-push-reminder"
					}
				]
			},
			{
				"matcher": "Write",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" block-random-docs"
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" suggest-compact"
					}
				]
			},
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/skills/continuous-learning/hooks/observe.sh pre"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" pre-compact"
					}
				]
			}
		],
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/session-start-guard.sh\" && \"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" session-start"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" pr-created-log"
					}
				]
			},
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" post-edit-format"
					}
				]
			},
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" post-edit-typecheck"
					}
				]
			},
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" post-edit-console-warn"
					}
				]
			},
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/skills/continuous-learning/hooks/observe.sh post"
					}
				]
			}
		],
		"Notification": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/notification.sh\""
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" check-console-log"
					},
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/notification.sh\""
					}
				]
			}
		],
		"SessionEnd": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" session-end"
					}
				]
			},
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/claudey\" evaluate-session"
					}
				]
			}
		]
	}
}
